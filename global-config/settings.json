{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "<YOUR_ANTHROPIC_TOKEN>",
    "ANTHROPIC_BASE_URL": "<YOUR_API_PROXY_URL_IF_NEEDED>",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-opus-4.6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-opus-4.6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4.6",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "model": "sonnet[1m]",
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "language": "Chinese",
  "codemossProviderId": "<YOUR_PROVIDER_ID>",
  "sessionRecording": {
    "enabled": true,
    "outputDirectory": "~/Desktop/claude-sessions",
    "format": "markdown",
    "includeTimestamps": true,
    "includeMetadata": true
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/sync-session-log.py",
            "timeout": 30,
            "statusMessage": "Syncing session log..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/sync-session-log.py --merge",
            "timeout": 60,
            "statusMessage": "Merging session logs..."
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "GitHub MCP Server": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_TOKEN>"
      },
      "type": "stdio",
      "disabled": false
    },
    "Alibaba Cloud Yunxiao DevOps": {
      "command": "npx",
      "args": [
        "-y",
        "alibabacloud-devops-mcp-server"
      ],
      "env": {
        "YUNXIAO_ACCESS_TOKEN": "<YOUR_YUNXIAO_TOKEN>",
        "YUNXIAO_API_BASE_URL": "https://openapi-rdc.aliyuncs.com"
      },
      "type": "stdio",
      "disabled": false
    }
  }
}
